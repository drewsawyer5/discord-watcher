# Copy this to .env and set values for your environment
# All vars are optional — defaults work for Drew's standard setup

# ── watcher.py (voice transcription) ──────────────────────────────────────
# Path to Discord voice inbox folder
DISCORD_INBOX=C:\Users\drews\.claude\channels\discord\inbox

# Path to MD-AI inbox log base folder
INBOX_LOG_DIR=C:\Users\drews\Life Org\MD-AI\00 - Inbox\logs

# Whisper model size: tiny, base, small, medium, large
WHISPER_MODEL=base

# ── ingest.py (URL ingest — no Claude session required) ───────────────────
# Discord bot token (same bot as the Claude MCP plugin)
DISCORD_BOT_TOKEN=

# Discord channel ID to watch for URLs (#inbox — ingest.py only)
INGEST_CHANNEL_ID=1474888214639546631

# Discord channel ID for the Claude --channels session (#general — used by discord_client.py)
CLAUDE_CHANNEL_ID=1474888067893559360

# Drew's Discord user ID — only process URLs from this user (optional but recommended)
# Find it: Discord → Settings → Advanced → enable Developer Mode → right-click your name → Copy User ID
DREW_USER_ID=

# Path to Obsidian vault root
VAULT_PATH=C:\Users\drews\Life Org\Obsidian

# How often to poll Discord for new messages (seconds)
INGEST_POLL_INTERVAL=30

# ── LLM provider (provider-agnostic) ──────────────────────────────────────
# Provider: gemini (default) | openai_compat (Ollama, OpenRouter, etc.)
LLM_PROVIDER=gemini

# API key for the LLM provider (Gemini API key for default setup)
LLM_API_KEY=

# Model name
LLM_MODEL=gemini-2.0-flash

# Base URL — change this to swap providers:
#   Gemini:  https://generativelanguage.googleapis.com/v1beta/openai/
#   Ollama:  http://localhost:11434/v1
#   OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ── Twitter/X ingest (PKW-04) ──────────────────────────────────────────────
# Credentials for a throwaway X account — used by twikit to fetch tweet content.
# Cookies are saved to twitter_cookies.json after first login (never pushed to git).
# Leave blank to disable Twitter ingest (blocked URLs will go to retry queue).
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=